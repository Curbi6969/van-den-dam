---
layout: base.njk
eleventyComputed:
  title: "{{ privacyverklaring.title }}"
  description: "{{ privacyverklaring.description }}"
---
<style>
 .prose h2 { font-family: 'Manrope', sans-serif; font-size: 1.375rem; font-weight: 700; color: #232227; margin-top: 2.5rem; margin-bottom: 0.75rem; }
 .prose p, .prose li { font-family: 'Work Sans', sans-serif; color: #45474d; line-height: 1.8; margin-bottom: 1rem; font-size: 0.9375rem; }
 .prose ul { list-style: disc; padding-left: 1.5rem; }
 .prose a { color: #ff0000; text-decoration: underline; }
 .prose a:hover { color: #232227; }
</style>

<!-- Content -->
<main class="max-w-3xl mx-auto px-6 pt-36 pb-24">

 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ privacyverklaring.eyebrow }}</span>
 <h1 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight mb-4" style="letter-spacing:-0.02em;">{{ privacyverklaring.heading }}</h1>
 <p class="font-body text-on-surface-variant mb-12">{{ privacyverklaring.lastUpdated }}</p>

 <div class="bg-surface-container-lowest rounded-xl p-8 md:p-12 ambient-shadow prose">
{%- for section in privacyverklaring.sections %}
 <h2>{{ section.heading }}</h2>
 {{ section.html | safe }}
{%- endfor %}
 </div>

 <div class="mt-10">
 <a href="index.html" class="inline-flex items-center gap-2 font-label text-sm text-secondary font-semibold hover:text-primary transition-colors">
 <span class="material-symbols-outlined text-base">arrow_back</span> {{ privacyverklaring.backLink }}
 </a>
 </div>
</main>
