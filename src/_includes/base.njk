<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title }}</title>
<meta name="description" content="{{ description }}"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Work+Sans:wght@300;400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>
<link rel="stylesheet" href="styles.css"/>
<style>
 /* Define the Material Symbols helper class locally so icon rendering never
    depends on Google serving it only to recognised browser User-Agents. */
 .material-symbols-outlined {
 font-family: 'Material Symbols Outlined';
 font-weight: normal;
 font-style: normal;
 line-height: 1;
 letter-spacing: normal;
 text-transform: none;
 display: inline-block;
 white-space: nowrap;
 word-wrap: normal;
 direction: ltr;
 -webkit-font-smoothing: antialiased;
 -webkit-font-feature-settings: 'liga';
 font-feature-settings: 'liga';
 }
 .ambient-shadow { box-shadow: 0 10px 40px rgba(35,34,39,0.06); }
 .ghost-border { border: 1px solid rgba(197,198,205,0.15); }
 .gradient-primary { background: linear-gradient(135deg, #232227 0%, #3a393e 100%); }
 #mobile-menu { display: none; }
 #mobile-menu.open { display: block; }
</style>
</head>
<body class="bg-surface text-on-surface font-body antialiased">

<!-- Navigation -->
<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300" style="background:rgba(251,248,255,0.85);backdrop-filter:blur(12px);box-shadow:0 10px 40px rgba(35,34,39,0.06);">
 <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
 <a href="index.html"><img src="resources/vandenDam-logo.jpg" alt="Van den Dam Schilderwerken" class="h-14 w-auto"/></a>
 <div class="hidden md:flex items-center gap-8 font-headline font-semibold text-sm tracking-tight">
 <a href="index.html" class="{% if nav == 'home' %}text-primary border-b-2 border-primary pb-0.5{% else %}text-on-surface-variant hover:text-primary transition-colors{% endif %}">Home</a>
 <div class="relative group">
 <a href="diensten.html" class="{% if nav == 'diensten' %}text-primary border-b-2 border-primary pb-0.5{% else %}text-on-surface-variant hover:text-primary transition-colors{% endif %} flex items-center gap-0.5">Diensten <span class="material-symbols-outlined" style="font-size:16px;line-height:1;vertical-align:middle;">expand_more</span></a>
 <div class="absolute top-full left-0 pt-3 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
 <div class="bg-white rounded-xl py-1" style="box-shadow:0 8px 30px rgba(35,34,39,0.12);">
{%- for service in site.services %}
 <a href="{{ service.url }}" class="block px-4 py-2.5 font-body text-sm text-on-surface-variant hover:text-primary hover:bg-surface-container-low transition-colors">{{ service.title }}</a>
{%- endfor %}
 </div>
 </div>
 </div>
 <a href="portfolio.html" class="{% if nav == 'portfolio' %}text-primary border-b-2 border-primary pb-0.5{% else %}text-on-surface-variant hover:text-primary transition-colors{% endif %}">Portfolio</a>
 <a href="over-ons.html" class="{% if nav == 'over-ons' %}text-primary border-b-2 border-primary pb-0.5{% else %}text-on-surface-variant hover:text-primary transition-colors{% endif %}">Over Ons</a>
 <a href="contact.html" class="{% if nav == 'contact' %}text-primary border-b-2 border-primary pb-0.5{% else %}text-on-surface-variant hover:text-primary transition-colors{% endif %}">Contact</a>
 </div>
 <a href="contact.html" class="hidden md:inline-block bg-secondary text-on-secondary font-label font-semibold text-sm px-5 py-2.5 rounded-md hover:opacity-90 transition-opacity">Offerte Aanvragen</a>
 <button id="menu-toggle" class="md:hidden text-primary" aria-label="Menu">
 <span class="material-symbols-outlined">menu</span>
 </button>
 </div>
 <div id="mobile-menu" class="md:hidden border-t border-outline-variant/20">
 <div class="px-6 py-4 flex flex-col gap-4 font-headline font-semibold text-sm bg-surface/95">
 <a href="index.html" class="{% if nav == 'home' %}text-primary{% else %}text-on-surface-variant{% endif %}">Home</a>
 <a href="diensten.html" class="{% if nav == 'diensten' %}text-primary{% else %}text-on-surface-variant{% endif %}">Diensten</a>
 <div class="pl-4 flex flex-col gap-1 mt-0.5">
{%- for service in site.services %}
 <a href="{{ service.url }}" class="text-on-surface-variant/80 font-normal font-body" style="font-size:0.75rem;">&#8627; {{ service.title }}</a>
{%- endfor %}
 </div>
 <a href="portfolio.html" class="{% if nav == 'portfolio' %}text-primary{% else %}text-on-surface-variant{% endif %}">Portfolio</a>
 <a href="over-ons.html" class="{% if nav == 'over-ons' %}text-primary{% else %}text-on-surface-variant{% endif %}">Over Ons</a>
 <a href="contact.html" class="{% if nav == 'contact' %}text-primary{% else %}text-on-surface-variant{% endif %}">Contact</a>
 <a href="contact.html" class="bg-secondary text-on-secondary font-label px-5 py-2.5 rounded-md text-center mt-2">Offerte Aanvragen</a>
 </div>
 </div>
</nav>

{{ content | safe }}

<!-- Footer -->
<footer style="background:#232227;" class="text-slate-100 py-16 px-6">
 <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-5 gap-10">
 <div class="md:col-span-1">
 <p class="font-headline text-lg font-extrabold text-white mb-4">{{ site.name }}</p>
 <p class="font-body text-sm text-slate-300 leading-relaxed mb-6">Het creëren van prachtige ruimtes met precisie en passie. Familiebedrijf sinds {{ site.founded }}.</p>
 <p class="font-body text-xs text-slate-400">&copy; 2026 {{ site.name }}.<br/>Alle rechten voorbehouden.</p>
 <p class="font-body text-xs text-slate-500 mt-2">Website gemaakt door <a href="{{ site.credit.url }}" target="_blank" rel="noopener noreferrer" class="underline hover:text-slate-300 transition-colors">{{ site.credit.name }}</a></p>
 </div>
 <div>
 <p class="font-label text-xs font-semibold tracking-widest text-slate-500 uppercase mb-4">Navigatie</p>
 <ul class="space-y-2 font-body text-sm">
 <li><a href="diensten.html" class="text-slate-300 hover:text-white transition-colors">Diensten</a></li>
 <li><a href="portfolio.html" class="text-slate-300 hover:text-white transition-colors">Portfolio</a></li>
 <li><a href="over-ons.html" class="text-slate-300 hover:text-white transition-colors">Over Ons</a></li>
 <li><a href="contact.html" class="text-slate-300 hover:text-white transition-colors">Contact</a></li>
 </ul>
 </div>
 <div>
 <p class="font-label text-xs font-semibold tracking-widest text-slate-500 uppercase mb-4">Contact</p>
 <ul class="space-y-3 font-body text-sm text-slate-300">
 <li>{{ site.contact.addressLine1 }}<br/>{{ site.contact.addressLine2 }}</li>
 <li><a href="tel:{{ site.contact.phoneHref }}" class="hover:text-white transition-colors">{{ site.contact.phoneDisplay }}</a></li>
 <li><a href="mailto:{{ site.contact.email }}" class="hover:text-white transition-colors break-all">{{ site.contact.email }}</a></li>
 </ul>
 </div>
 <div>
 <p class="font-label text-xs font-semibold tracking-widest text-slate-500 uppercase mb-4">Bedrijfsgegevens</p>
 <ul class="space-y-3 font-body text-sm text-slate-300">
 <li><span class="text-slate-500 text-xs uppercase tracking-wide block mb-0.5">KvK</span>{{ site.business.kvk }}</li>
 <li><span class="text-slate-500 text-xs uppercase tracking-wide block mb-0.5">{{ site.business.bankName }}</span>{{ site.business.bankAccount }}</li>
 </ul>
 <p class="font-label text-xs font-semibold tracking-widest text-slate-500 uppercase mb-2 mt-6">Juridisch</p>
 <ul class="space-y-2 font-body text-sm">
 <li><a href="privacyverklaring.html" class="text-slate-300 hover:text-white transition-colors">Privacyverklaring</a></li>
 </ul>
 </div>
 <div>
 <p class="font-label text-xs font-semibold tracking-widest text-slate-500 uppercase mb-4">Erkend Vakbedrijf</p>
 <img src="resources/onderhoudnl-logo.png" alt="OnderhoudNL keurmerk" class="h-16 w-auto mb-4 rounded"/>
 <p class="font-body text-xs text-slate-300 leading-relaxed">Van den Dam is aangesloten bij <a href="https://www.onderhoudnl.nl/over-onderhoudnl" target="_blank" rel="noopener noreferrer" class="text-white underline hover:text-slate-300 transition-colors">OnderhoudNL (FOSAG)</a> de branchevereniging voor erkende schilders- en afwerkingsbedrijven.</p>
 </div>
 </div>
</footer>

<script src="site.js"></script>
</body>
</html>
