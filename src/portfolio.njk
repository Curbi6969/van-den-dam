---
layout: base.njk
nav: portfolio
eleventyComputed:
  title: "{{ portfolio.title }}"
  description: "{{ portfolio.description }}"
---
<!-- Hero -->
<section class="max-w-7xl mx-auto px-6 pt-40 pb-16">
 <div class="max-w-3xl">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ portfolio.hero.eyebrow }}</span>
 <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-primary tracking-tight mb-6" style="letter-spacing:-0.02em;">{{ portfolio.hero.title }}</h1>
 <p class="font-body text-xl text-on-surface-variant leading-relaxed">
 {{ portfolio.hero.subtitle }}
 </p>
 </div>
</section>

<!-- Filter Chips -->
<section class="max-w-7xl mx-auto px-6 mb-12">
 <div class="flex flex-wrap gap-3">
 <button onclick="filterPortfolio('all', this)" class="filter-btn active bg-secondary text-on-secondary px-6 py-2 rounded-full font-label text-sm font-semibold tracking-wide transition-all">{{ portfolio.filters[0].label }}</button>
 <button onclick="filterPortfolio('interieur', this)" class="filter-btn bg-surface-container text-on-surface px-6 py-2 rounded-full font-label text-sm font-semibold tracking-wide ghost-border hover:bg-surface-container-high transition-all">{{ portfolio.filters[1].label }}</button>
 <button onclick="filterPortfolio('exterieur', this)" class="filter-btn bg-surface-container text-on-surface px-6 py-2 rounded-full font-label text-sm font-semibold tracking-wide ghost-border hover:bg-surface-container-high transition-all">{{ portfolio.filters[2].label }}</button>
 <button onclick="filterPortfolio('speciaal', this)" class="filter-btn bg-surface-container text-on-surface px-6 py-2 rounded-full font-label text-sm font-semibold tracking-wide ghost-border hover:bg-surface-container-high transition-all">{{ portfolio.filters[3].label }}</button>
 </div>
</section>

<!-- Portfolio Grid -->
<section class="max-w-7xl mx-auto px-6 pb-24">
 <div class="grid grid-cols-1 md:grid-cols-12 gap-6" style="grid-auto-rows:320px;">

 <article data-cat="{{ portfolio.projects[0].cat }}" class="portfolio-item md:col-span-8 md:row-span-2 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ portfolio.projects[0].image }}" alt="{{ portfolio.projects[0].imageAlt }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/30 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>
 <div class="absolute bottom-0 p-8">
 <span class="inline-block bg-white/20 backdrop-blur-md text-white font-label text-xs uppercase tracking-wider px-3 py-1 rounded-sm mb-4">{{ portfolio.projects[0].categoryLabel }}</span>
 <h2 class="font-headline text-2xl md:text-3xl font-bold text-white mb-2">{{ portfolio.projects[0].title }}</h2>
 <p class="font-body text-slate-200 max-w-xl text-sm line-clamp-2">{{ portfolio.projects[0].description }}</p>
 </div>
 </article>

 <article data-cat="{{ portfolio.projects[1].cat }}" class="portfolio-item md:col-span-4 md:row-span-2 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ portfolio.projects[1].image }}" alt="{{ portfolio.projects[1].imageAlt }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent opacity-80"></div>
 <div class="absolute bottom-0 p-8">
 <span class="inline-block bg-white/20 backdrop-blur-md text-white font-label text-xs uppercase tracking-wider px-3 py-1 rounded-sm mb-4">{{ portfolio.projects[1].categoryLabel }}</span>
 <h2 class="font-headline text-xl font-bold text-white mb-2">{{ portfolio.projects[1].title }}</h2>
 <p class="font-body text-slate-200 text-sm line-clamp-2">{{ portfolio.projects[1].description }}</p>
 </div>
 </article>

 <article data-cat="{{ portfolio.projects[2].cat }}" class="portfolio-item md:col-span-4 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ portfolio.projects[2].image }}" alt="{{ portfolio.projects[2].imageAlt }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-transparent to-transparent opacity-80"></div>
 <div class="absolute bottom-0 p-6">
 <span class="inline-block bg-white/20 backdrop-blur-md text-white font-label text-xs uppercase tracking-wider px-3 py-1 rounded-sm mb-3">{{ portfolio.projects[2].categoryLabel }}</span>
 <h2 class="font-headline text-lg font-bold text-white mb-1">{{ portfolio.projects[2].title }}</h2>
 <p class="font-body text-sm text-slate-200 line-clamp-1">{{ portfolio.projects[2].description }}</p>
 </div>
 </article>

 <article data-cat="{{ portfolio.projects[3].cat }}" class="portfolio-item md:col-span-4 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ portfolio.projects[3].image }}" alt="{{ portfolio.projects[3].imageAlt }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-transparent to-transparent opacity-80"></div>
 <div class="absolute bottom-0 p-6">
 <span class="inline-block bg-white/20 backdrop-blur-md text-white font-label text-xs uppercase tracking-wider px-3 py-1 rounded-sm mb-3">{{ portfolio.projects[3].categoryLabel }}</span>
 <h2 class="font-headline text-lg font-bold text-white mb-1">{{ portfolio.projects[3].title }}</h2>
 <p class="font-body text-sm text-slate-200 line-clamp-1">{{ portfolio.projects[3].description }}</p>
 </div>
 </article>

 <article data-cat="{{ portfolio.projects[4].cat }}" class="portfolio-item md:col-span-4 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ portfolio.projects[4].image }}" alt="{{ portfolio.projects[4].imageAlt }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-transparent to-transparent opacity-80"></div>
 <div class="absolute bottom-0 p-6">
 <span class="inline-block bg-white/20 backdrop-blur-md text-white font-label text-xs uppercase tracking-wider px-3 py-1 rounded-sm mb-3">{{ portfolio.projects[4].categoryLabel }}</span>
 <h2 class="font-headline text-lg font-bold text-white mb-1">{{ portfolio.projects[4].title }}</h2>
 <p class="font-body text-sm text-slate-200 line-clamp-1">{{ portfolio.projects[4].description }}</p>
 </div>
 </article>

 </div>
</section>

<!-- CTA -->
<section class="max-w-4xl mx-auto px-6 pb-28 text-center">
 <div class="bg-surface-container-low p-12 md:p-16 rounded-2xl ghost-border ambient-shadow relative overflow-hidden">
 <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary-container rounded-full opacity-10 blur-3xl pointer-events-none"></div>
 <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-secondary-container rounded-full opacity-10 blur-3xl pointer-events-none"></div>
 <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-primary mb-6 relative z-10">{{ portfolio.cta.title }}</h2>
 <p class="font-body text-lg text-on-surface-variant mb-10 max-w-2xl mx-auto relative z-10">{{ portfolio.cta.text }}</p>
 <a href="{{ portfolio.cta.href }}" class="relative z-10 inline-block bg-secondary text-on-secondary font-label font-semibold px-10 py-4 rounded-md hover:opacity-90 transition-opacity text-lg">
 {{ portfolio.cta.button }}
 </a>
 </div>
</section>

<script>
 function filterPortfolio(cat, btn) {
 document.querySelectorAll('.filter-btn').forEach(b => {
 b.classList.remove('bg-secondary','text-on-secondary');
 b.classList.add('bg-surface-container','text-on-surface');
 });
 btn.classList.add('bg-secondary','text-on-secondary');
 btn.classList.remove('bg-surface-container','text-on-surface');

 document.querySelectorAll('.portfolio-item').forEach(item => {
 if (cat === 'all' || item.dataset.cat === cat) {
 item.style.display = '';
 } else {
 item.style.display = 'none';
 }
 });
 }
</script>
