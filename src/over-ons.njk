---
layout: base.njk
nav: over-ons
eleventyComputed:
  title: "{{ overons.title }}"
  description: "{{ overons.description }}"
---
<!-- Hero -->
<section class="max-w-7xl mx-auto px-6 pt-40 pb-24">
 <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
 <div class="lg:col-span-5">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ overons.hero.eyebrow }}</span>
 <h1 class="font-headline text-5xl lg:text-7xl font-extrabold text-primary tracking-tight leading-tight mb-8" style="letter-spacing:-0.02em;">
 {{ overons.hero.title }}
 </h1>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-10 max-w-lg">
 {{ overons.hero.text }}
 </p>
 <a href="{{ overons.hero.ctaHref }}" class="inline-flex items-center gap-2 bg-secondary text-on-secondary font-label font-semibold px-7 py-3.5 rounded-md hover:opacity-90 transition-opacity">
 {{ overons.hero.ctaLabel }} <span class="material-symbols-outlined text-sm">arrow_forward</span>
 </a>
 </div>
 <div class="lg:col-span-7 relative">
 <div class="aspect-[4/3] rounded-xl overflow-hidden ambient-shadow">
 <img src="{{ overons.hero.image }}" alt="{{ overons.hero.imageAlt }}" class="w-full h-full object-cover"/>
 </div>
 </div>
 </div>
</section>

<!-- Values -->
<section class="bg-surface-container-low py-24">
 <div class="max-w-7xl mx-auto px-6">
 <div class="max-w-2xl mb-16">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ overons.values.eyebrow }}</span>
 <h2 class="font-headline text-3xl md:text-4xl font-extrabold text-primary tracking-tight">{{ overons.values.heading }}</h2>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
{%- for item in overons.values.items %}
{%- if item.raised %}
 <div class="bg-surface-container-lowest p-10 rounded-xl ambient-shadow ghost-border md:translate-y-8 hover:translate-y-6 transition-transform duration-300">
{%- else %}
 <div class="bg-surface-container-lowest p-10 rounded-xl ambient-shadow ghost-border hover:-translate-y-2 transition-transform duration-300">
{%- endif %}
 <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center mb-6">
 <span class="material-symbols-outlined text-secondary">{{ item.icon }}</span>
 </div>
 <h3 class="font-headline text-xl font-bold text-primary mb-4">{{ item.title }}</h3>
 <p class="font-body text-on-surface-variant text-sm leading-relaxed">
 {{ item.text }}
 </p>
 </div>
{%- endfor %}
 </div>
 </div>
</section>

<!-- Team & Craftsmanship -->
<section class="max-w-7xl mx-auto px-6 py-28">
 <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
 <div class="order-2 lg:order-1 relative">
 <div class="grid grid-cols-2 gap-6">
 <div class="space-y-6 mt-12">
 <img src="{{ overons.team.image1 }}" alt="{{ overons.team.image1Alt }}" class="rounded-xl w-full h-52 object-cover ambient-shadow"/>
 <div class="bg-surface-container-highest p-6 rounded-xl">
 <p class="font-label text-sm text-on-surface font-medium italic">"{{ overons.team.quote }}"</p>
 </div>
 </div>
 <div>
 <img src="{{ overons.team.image2 }}" alt="{{ overons.team.image2Alt }}" class="rounded-xl w-full h-72 object-cover ambient-shadow"/>
 </div>
 </div>
 </div>
 <div class="order-1 lg:order-2 lg:pl-12">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ overons.team.eyebrow }}</span>
 <h2 class="font-headline text-4xl font-extrabold text-primary tracking-tight mb-8">{{ overons.team.heading }}</h2>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-6">
 {{ overons.team.paragraph1 }}
 </p>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-10">
 {{ overons.team.paragraph2 }}
 </p>
 <a href="{{ overons.team.ctaHref }}" class="inline-flex items-center gap-2 text-primary font-label font-bold border-b-2 border-primary pb-1 hover:text-secondary hover:border-secondary transition-colors">
 {{ overons.team.ctaLabel }} <span class="material-symbols-outlined text-sm">arrow_forward</span>
 </a>
 </div>
 </div>
</section>
