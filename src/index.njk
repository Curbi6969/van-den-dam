---
layout: base.njk
nav: home
eleventyComputed:
  title: "{{ home.title }}"
  description: "{{ home.description }}"
---
<!-- Hero -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
 <div class="absolute inset-0 z-0">
 <img src="{{ home.hero.image }}" alt="" class="w-full h-full object-cover"/>
 <div class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/50 to-transparent"></div>
 </div>
 <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32 pb-20 w-full">
 <div class="max-w-2xl">
 <span class="font-label text-xs font-semibold tracking-widest text-white/70 uppercase mb-6 block tracking-[0.2em]">{{ home.hero.eyebrow }}</span>
 <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-white leading-tight tracking-tight mb-8" style="letter-spacing:-0.02em;">
 {{ home.hero.title }}
 </h1>
 <p class="font-body text-xl text-white/80 leading-relaxed mb-10 max-w-xl">
 {{ home.hero.subtitle }}
 </p>
 <div class="flex flex-wrap gap-4">
 <a href="contact.html" class="bg-secondary text-on-secondary font-label font-semibold px-8 py-4 rounded-md hover:opacity-90 transition-opacity ambient-shadow">
 Offerte Aanvragen
 </a>
 <a href="portfolio.html" class="bg-white/10 backdrop-blur-md border border-white/20 text-white font-label font-semibold px-8 py-4 rounded-md hover:bg-white/20 transition-colors">
 Bekijk Portfolio
 </a>
 </div>
 </div>
 </div>
</section>

<!-- Trust Bar -->
<section class="bg-surface-container-lowest relative z-20 -mt-6 mx-4 md:mx-auto max-w-4xl rounded-2xl ambient-shadow ghost-border px-8 py-8">
 <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 text-center md:text-left">
{%- for item in home.trust %}
 <div class="flex items-center gap-4">
 <span class="material-symbols-outlined text-4xl text-secondary" style="font-variation-settings:'FILL' 1;">{{ item.icon }}</span>
 <div>
 <p class="font-headline font-bold text-primary">{{ item.title }}</p>
 <p class="font-body text-sm text-on-surface-variant">{{ item.subtitle }}</p>
 </div>
 </div>
{%- if not loop.last %}
 <div class="hidden md:block w-px h-10 bg-outline-variant/40"></div>
{%- endif %}
{%- endfor %}
 </div>
</section>

<!-- Services Preview -->
<section class="py-28 bg-surface">
 <div class="max-w-7xl mx-auto px-6">
 <div class="max-w-2xl mb-16">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ home.servicesIntro.eyebrow }}</span>
 <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight mb-4">{{ home.servicesIntro.title }}</h2>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed">{{ home.servicesIntro.text }}</p>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
{%- for card in home.servicesCards %}
 <div class="group bg-surface-container-lowest rounded-xl overflow-hidden ambient-shadow ghost-border flex flex-col hover:-translate-y-1 transition-transform duration-300{% if card.raised %} md:-translate-y-6{% endif %}">
 <div class="h-56 overflow-hidden">
 <img src="{{ card.image }}" alt="{{ card.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
 </div>
 <div class="p-8 flex-1 flex flex-col">
 <h3 class="font-headline text-xl font-bold text-primary mb-3">{{ card.title }}</h3>
 <p class="font-body text-on-surface-variant mb-6 flex-1 text-sm leading-relaxed">{{ card.text }}</p>
 <a href="diensten.html" class="font-label text-sm text-secondary font-semibold inline-flex items-center gap-1 hover:text-primary transition-colors">
 Meer lezen <span class="material-symbols-outlined text-base">arrow_forward</span>
 </a>
 </div>
 </div>
{%- endfor %}
 </div>
 <div class="mt-12 text-center">
 <a href="diensten.html" class="inline-flex items-center gap-2 bg-secondary text-on-secondary font-label font-semibold px-8 py-4 rounded-md hover:opacity-90 transition-opacity">
 Bekijk al onze diensten <span class="material-symbols-outlined text-sm">arrow_forward</span>
 </a>
 </div>
 </div>
</section>

<!-- About Teaser -->
<section class="bg-surface-container-low py-28">
 <div class="max-w-7xl mx-auto px-6">
 <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
 <div class="relative">
 <div class="rounded-xl overflow-hidden ambient-shadow aspect-[4/3]">
 <img src="{{ home.about.image }}" alt="Ons team" class="w-full h-full object-cover"/>
 </div>
 <div class="absolute -bottom-6 -right-6 bg-surface-container-lowest rounded-xl p-6 ambient-shadow ghost-border hidden md:block">
 <p class="font-headline text-4xl font-extrabold text-primary">{{ home.about.badgeNumber }}</p>
 <p class="font-body text-sm text-on-surface-variant">{{ home.about.badgeLabel }}</p>
 </div>
 </div>
 <div>
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ home.about.eyebrow }}</span>
 <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight mb-6">{{ home.about.title }}</h2>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-6">
 {{ home.about.paragraph1 }}
 </p>
 <p class="font-body text-lg text-on-surface-variant leading-relaxed mb-10">
 {{ home.about.paragraph2 }}
 </p>
 <a href="over-ons.html" class="inline-flex items-center gap-2 text-primary font-label font-bold border-b-2 border-primary pb-1 hover:text-secondary hover:border-secondary transition-colors">
 Leer ons kennen <span class="material-symbols-outlined text-sm">arrow_forward</span>
 </a>
 </div>
 </div>
 </div>
</section>

<!-- Portfolio Teaser -->
<section class="py-28 bg-surface">
 <div class="max-w-7xl mx-auto px-6">
 <div class="flex items-end justify-between mb-12">
 <div>
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ home.portfolioIntro.eyebrow }}</span>
 <h2 class="font-headline text-4xl font-extrabold text-primary tracking-tight">{{ home.portfolioIntro.title }}</h2>
 </div>
 <a href="portfolio.html" class="hidden md:inline-flex items-center gap-2 font-label text-sm text-secondary font-semibold hover:text-primary transition-colors">
 Volledig portfolio <span class="material-symbols-outlined text-base">arrow_forward</span>
 </a>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[480px]">
 <article class="md:col-span-8 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ home.portfolio[0].image }}" alt="{{ home.portfolio[0].title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent"></div>
 <div class="absolute bottom-0 p-8">
 <span class="text-white/70 font-label text-xs uppercase tracking-wider mb-2 block">{{ home.portfolio[0].category }}</span>
 <h3 class="font-headline text-2xl font-bold text-white">{{ home.portfolio[0].title }}</h3>
 </div>
 </article>
 <div class="md:col-span-4 flex flex-col gap-6">
{%- for item in home.portfolio.slice(1) %}
 <article class="flex-1 relative group overflow-hidden rounded-xl ambient-shadow ghost-border cursor-pointer">
 <img src="{{ item.image }}" alt="{{ item.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"/>
 <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
 <div class="absolute bottom-0 p-6">
 <span class="text-white/70 font-label text-xs uppercase tracking-wider mb-1 block">{{ item.category }}</span>
 <h3 class="font-headline text-lg font-bold text-white">{{ item.title }}</h3>
 </div>
 </article>
{%- endfor %}
 </div>
 </div>
 <div class="mt-8 md:hidden">
 <a href="portfolio.html" class="inline-flex items-center gap-2 font-label text-sm text-secondary font-semibold hover:text-primary transition-colors">
 Volledig portfolio <span class="material-symbols-outlined text-base">arrow_forward</span>
 </a>
 </div>
 </div>
</section>


<!-- Reviews -->
<section class="py-28 bg-surface">
 <div class="max-w-7xl mx-auto px-6">
 <div class="text-center mb-16">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-4 block">{{ home.reviewsIntro.eyebrow }}</span>
 <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight" style="letter-spacing:-0.02em;">{{ home.reviewsIntro.title }}</h2>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
{%- for review in home.reviews %}
 <div class="bg-surface-container-lowest rounded-xl p-8 ambient-shadow ghost-border flex flex-col gap-4">
 <div class="flex gap-1 text-secondary">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
 <p class="font-body text-on-surface-variant leading-relaxed">"{{ review.quote }}"</p>
 <p class="font-label text-sm font-semibold text-primary mt-auto">{{ review.name }}</p>
 </div>
{%- endfor %}
 </div>
 <p class="text-center font-body text-sm text-on-surface-variant mt-10">Gemiddeld <strong class="text-primary">{{ home.reviewScore }}</strong> op basis van {{ home.reviewCount }} beoordelingen</p>
 </div>
</section>

<!-- CTA -->
<section class="bg-surface-container-low py-28">
 <div class="max-w-3xl mx-auto px-6 text-center">
 <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight mb-6">{{ home.cta.title }}</h2>
 <p class="font-body text-xl text-on-surface-variant mb-10">{{ home.cta.text }}</p>
 <a href="contact.html" class="inline-block bg-secondary text-on-secondary font-label font-semibold text-lg px-10 py-4 rounded-md hover:opacity-90 transition-opacity ambient-shadow">
 {{ home.cta.button }}
 </a>
 </div>
</section>
