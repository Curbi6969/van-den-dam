---
layout: base.njk
nav: diensten
eleventyComputed:
  title: "{{ diensten.title }}"
  description: "{{ diensten.description }}"
---
<!-- Hero -->
<section class="relative pt-32 pb-24 overflow-hidden" style="background:linear-gradient(135deg,#232227 0%,#3a393e 100%);">
 <div class="max-w-7xl mx-auto px-6 relative z-10">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-6 block">{{ diensten.hero.eyebrow }}</span>
 <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-6 max-w-4xl" style="letter-spacing:-0.02em;">{{ diensten.hero.title }}</h1>
 <p class="font-body text-xl text-primary-fixed-dim max-w-2xl leading-relaxed">
 {{ diensten.hero.subtitle }}
 </p>
 </div>
 <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white/5 to-transparent pointer-events-none"></div>
</section>

<!-- Binnenwerk -->
<section class="py-20 bg-surface-container-low">
 <div class="max-w-7xl mx-auto px-6">
 <div class="mb-10">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase">{{ diensten.binnenwerk.eyebrow }}</span>
 <h2 class="font-headline text-3xl font-extrabold text-primary mt-2" style="letter-spacing:-0.01em;">{{ diensten.binnenwerk.heading }}</h2>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

{%- for item in diensten.binnenwerk.items %}
 <div class="bg-surface-container-lowest rounded-xl overflow-hidden ambient-shadow flex flex-col">
 <div class="overflow-hidden h-56">
 <img src="{{ item.image }}" alt="{{ item.imageAlt }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"/>
 </div>
 <div class="p-8 flex flex-col flex-grow">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-3">{{ item.categoryLabel }}</span>
 <h3 class="font-headline text-2xl font-bold text-primary mb-3">{{ item.title }}</h3>
 <p class="font-body text-on-surface-variant leading-relaxed flex-grow">
 {{ item.text }}
 </p>
 <a href="{{ item.linkHref }}" class="mt-6 inline-flex items-center gap-2 font-label text-sm font-semibold text-secondary hover:text-primary transition-colors">
 {{ item.linkLabel }} <span class="material-symbols-outlined text-base">arrow_forward</span>
 </a>
 </div>
 </div>
{%- endfor %}

 </div>
 </div>
</section>

<!-- Buitenwerk -->
<section class="py-20 bg-surface">
 <div class="max-w-7xl mx-auto px-6">
 <div class="mb-10">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase">{{ diensten.buitenwerk.eyebrow }}</span>
 <h2 class="font-headline text-3xl font-extrabold text-primary mt-2" style="letter-spacing:-0.01em;">{{ diensten.buitenwerk.heading }}</h2>
 </div>
 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

{%- for item in diensten.buitenwerk.items %}
 <div class="bg-surface-container-lowest rounded-xl overflow-hidden ambient-shadow flex flex-col">
 <div class="overflow-hidden h-48">
 <img src="{{ item.image }}" alt="{{ item.imageAlt }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"/>
 </div>
 <div class="p-7 flex flex-col flex-grow">
 <span class="font-label text-xs font-semibold tracking-widest text-secondary uppercase mb-3">{{ item.categoryLabel }}</span>
 <h3 class="font-headline text-xl font-bold text-primary mb-3">{{ item.title }}</h3>
 <p class="font-body text-sm text-on-surface-variant leading-relaxed flex-grow">
 {{ item.text }}
 </p>
 <a href="{{ item.linkHref }}" class="mt-5 inline-flex items-center gap-2 font-label text-sm font-semibold text-secondary hover:text-primary transition-colors">
 {{ item.linkLabel }} <span class="material-symbols-outlined text-base">arrow_forward</span>
 </a>
 </div>
 </div>
{%- endfor %}

 </div>
 </div>
</section>

<!-- CTA -->
<section class="bg-surface-container-low py-28 px-6">
 <div class="max-w-3xl mx-auto text-center">
 <h2 class="font-headline text-4xl md:text-5xl font-extrabold text-primary tracking-tight mb-6" style="letter-spacing:-0.02em;">{{ diensten.cta.title }}</h2>
 <p class="font-body text-xl text-on-surface-variant mb-10">{{ diensten.cta.text }}</p>
 <a href="{{ diensten.cta.href }}" class="inline-flex items-center gap-2 bg-secondary text-on-secondary font-label font-semibold px-8 py-4 rounded-md hover:opacity-90 transition-opacity">
 {{ diensten.cta.button }} <span class="material-symbols-outlined text-sm">arrow_forward</span>
 </a>
 </div>
</section>
